# Database (Railway will provide PostgreSQL URL)
DATABASE_URL=postgresql://user:password@localhost:5432/mint

# Redis (Railway will provide Redis URL)
REDIS_URL=redis://localhost:6379

# Next.js Configuration
NEXT_PUBLIC_APP_URL=https://your-app-name.up.railway.app
NODE_ENV=production

# Authentication
NEXTAUTH_SECRET=your_secret_here_generate_with_openssl_rand_-base64_32
NEXTAUTH_URL=https://your-app-name.up.railway.app

# Email Service (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# API Configuration (optional)
API_PORT=3000
